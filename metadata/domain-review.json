{
  "repo": "copper-model-feature-dock",
  "language": "Haskell",
  "category": "ML utilities",
  "goal": "Create a Haskell reference implementation for feature workflows, centered on diagnostic reporting, negative fixtures, and human-readable error snapshots.",
